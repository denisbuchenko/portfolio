{
  "name": "particle-system-attractors",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 3000 --strictPort",
    "build": "tsc -p tsconfig.json && vite build",
    "pages:prepare": "node ./scripts/prepare-pages-repo.mjs",
    "pages:clean": "node ./scripts/clean-pages-repo.mjs",
    "build:pages": "npm run pages:prepare && npm run pages:clean && tsc -p tsconfig.json && vite build --mode pages",
    "pages:status": "git -C ./.pages/denis-portfolio status --short",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173 --strictPort"
  },
  "dependencies": {
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-edgehandles": "^4.0.1",
    "dagre": "^0.8.5",
    "lottie-web": "^5.13.0",
    "three": "^0.160.0",
    "three-mesh-bvh": "^0.9.8",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/three": "^0.182.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  }
}
